{
  "info": {
    "name": "ZadoDB",
    "description": "Collection para a API REST do ZadoDB. Serve como cliente de referência para qualquer linguagem. O request 'Create object' captura o id em {{objectId}} para os requests seguintes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:7373" },
    { "key": "className", "value": "Pessoa" },
    { "key": "objectId", "value": "1" },
    { "key": "project", "value": "" }
  ],
  "item": [
    {
      "name": "Health & Stats",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/v1/health" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
              ] }
            }
          ]
        },
        {
          "name": "Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/v1/stats" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Classes",
      "item": [
        {
          "name": "Create class",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{className}}\"\n}" },
            "url": "{{baseUrl}}/v1/classes"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('created or exists', () => pm.expect([201,409]).to.include(pm.response.code));"
              ] }
            }
          ]
        },
        {
          "name": "List classes",
          "request": { "method": "GET", "url": "{{baseUrl}}/v1/classes" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('has classes array', () => pm.expect(pm.response.json().classes).to.be.an('array'));"
              ] }
            }
          ]
        },
        {
          "name": "Get class",
          "request": { "method": "GET", "url": "{{baseUrl}}/v1/classes/{{className}}" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "Delete class (if empty)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/v1/classes/{{className}}" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('204 or 409', () => pm.expect([204,409,404]).to.include(pm.response.code));"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Objects",
      "item": [
        {
          "name": "Create object",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"João\",\n  \"idade\": 30\n}" },
            "url": "{{baseUrl}}/v1/classes/{{className}}/objects"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "const id = pm.response.json().id;",
                "pm.expect(id).to.be.a('number');",
                "pm.collectionVariables.set('objectId', id);"
              ] }
            }
          ]
        },
        {
          "name": "Create objects (bulk)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "[\n  { \"nome\": \"Ana\" },\n  { \"nome\": \"Bruno\" },\n  { \"nome\": \"Carla\" }\n]" },
            "url": "{{baseUrl}}/v1/classes/{{className}}/objects/bulk"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "const j = pm.response.json();",
                "pm.test('returns ids', () => pm.expect(j.ids).to.be.an('array'));",
                "pm.test('count matches', () => pm.expect(j.count).to.eql(j.ids.length));"
              ] }
            }
          ]
        },
        {
          "name": "Get object",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-Zado-Project", "value": "{{project}}", "description": "Namespace virtual (projeto). Opcional em qualquer rota de classes/objetos; vazio = projeto padrão." } ],
            "url": "{{baseUrl}}/v1/classes/{{className}}/objects/{{objectId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('id matches', () => pm.expect(String(pm.response.json().id)).to.eql(pm.collectionVariables.get('objectId')));"
              ] }
            }
          ]
        },
        {
          "name": "Update object",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"João Neto\",\n  \"idade\": 31\n}" },
            "url": "{{baseUrl}}/v1/classes/{{className}}/objects/{{objectId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "List objects",
          "request": { "method": "GET", "url": "{{baseUrl}}/v1/classes/{{className}}/objects?limit=100&offset=0" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('has objects array', () => pm.expect(pm.response.json().objects).to.be.an('array'));"
              ] }
            }
          ]
        },
        {
          "name": "Query objects (eq + like)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/classes/{{className}}/objects?like.nome=%25nio%25ivo%25&limit=100",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1", "classes", "{{className}}", "objects" ],
              "query": [
                { "key": "like.nome", "value": "%25nio%25ivo%25", "description": "SQL LIKE: %=any, _=one char (case-insensitive by default)" },
                { "key": "eq.uf", "value": "SP", "disabled": true, "description": "exact match on a field" },
                { "key": "ci", "value": "false", "disabled": true, "description": "opt into case-sensitive" },
                { "key": "limit", "value": "100" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "Delete object",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/v1/classes/{{className}}/objects/{{objectId}}" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('204 No Content', () => pm.response.to.have.status(204));"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Projects (X-Zado-Project)",
      "description": "O header opcional `X-Zado-Project` seleciona um namespace virtual que agrupa classes. Ausente ou vazio = projeto padrão. Vale para qualquer rota de classes/objetos. Controle-o pela variável de collection {{project}}.",
      "item": [
        {
          "name": "List classes (projeto)",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-Zado-Project", "value": "{{project}}", "description": "Namespace virtual; vazio = projeto padrão." } ],
            "url": "{{baseUrl}}/v1/classes"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('has classes array', () => pm.expect(pm.response.json().classes).to.be.an('array'));"
              ] }
            }
          ]
        },
        {
          "name": "Create object (projeto)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Zado-Project", "value": "{{project}}", "description": "Cria o objeto dentro do projeto informado; vazio = projeto padrão." }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"codigoIbge\": 2408102,\n  \"nome\": \"Mossoró\",\n  \"codigoUf\": 24\n}" },
            "url": "{{baseUrl}}/v1/classes/municipio/objects"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Relationships (foreign keys)",
      "description": "Relacionamentos declaram foreign keys entre classes: `localField` na classe atual aponta para `remoteField` em `toClass`. Uma vez declarados, habilitam filtros por join `eq.<rel>.<campo>` e `like.<rel>.<campo>`. Dataset de exemplo: logradouro.municipioCodigo -> municipio.codigoIbge; municipio.codigoUf -> uf.codigoUf.",
      "item": [
        {
          "name": "Create relationship (logradouro -> municipio)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"municipio\",\n  \"localField\": \"municipioCodigo\",\n  \"toClass\": \"municipio\",\n  \"remoteField\": \"codigoIbge\"\n}" },
            "url": "{{baseUrl}}/v1/classes/logradouro/relationships"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('created or exists', () => pm.expect([201,409]).to.include(pm.response.code));"
              ] }
            }
          ]
        },
        {
          "name": "List relationships",
          "request": { "method": "GET", "url": "{{baseUrl}}/v1/classes/logradouro/relationships" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "Delete relationship (municipio)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/v1/classes/logradouro/relationships/municipio" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('204 or 404', () => pm.expect([204,404]).to.include(pm.response.code));"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Joins & filtros",
      "description": "Filtros por classe relacionada usam a sintaxe `eq.<rel>.<campo>` (igualdade) e `like.<rel>.<campo>` (SQL LIKE: %=qualquer sequência, _=um caractere). Por padrão os filtros ignoram caixa (`ci=true`) e acento (`ai=true`); passe `ci=false` para diferenciar maiúsc./minúsc. e `ai=false` para diferenciar acentos.",
      "item": [
        {
          "name": "Join + folding acento/caixa (default)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/classes/logradouro/objects?eq.uf.sigla=RN&like.municipio.nome=mossor%25&limit=100",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1", "classes", "logradouro", "objects" ],
              "query": [
                { "key": "eq.uf.sigla", "value": "RN", "description": "Filtra por classe relacionada `uf` (via municipio.codigoUf -> uf.codigoUf): apenas logradouros cuja UF tem sigla RN." },
                { "key": "like.municipio.nome", "value": "mossor%25", "description": "Filtra por classe relacionada `municipio`: nome começando com 'mossor'. Por default ignora acento e caixa, então casa 'Mossoró'." },
                { "key": "limit", "value": "100" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('has objects array', () => pm.expect(pm.response.json().objects).to.be.an('array'));"
              ] }
            }
          ]
        },
        {
          "name": "Join acento-sensível (ai=false)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/classes/logradouro/objects?eq.uf.sigla=RN&like.municipio.nome=mossor%25&ai=false&limit=100",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1", "classes", "logradouro", "objects" ],
              "query": [
                { "key": "eq.uf.sigla", "value": "RN", "description": "Mesmo join por UF." },
                { "key": "like.municipio.nome", "value": "mossor%25", "description": "Com `ai=false` o acento importa: 'mossor%' NÃO casa 'Mossoró' (mas casaria 'Mossoro' sem acento)." },
                { "key": "ai", "value": "false", "description": "Acento-sensível (default é true = ignora acento)." },
                { "key": "ci", "value": "true", "disabled": true, "description": "Caixa: default true (ignora). Passe false para diferenciar maiúsc./minúsc." },
                { "key": "limit", "value": "100" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "Join + include (embute objetos pai)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/classes/logradouro/objects?eq.uf.sigla=RN&eq.municipio.nome=mossoro&include=municipio,uf&limit=5",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1", "classes", "logradouro", "objects" ],
              "query": [
                { "key": "eq.uf.sigla", "value": "RN" },
                { "key": "eq.municipio.nome", "value": "mossoro", "description": "Folding default: casa 'Mossoró'." },
                { "key": "include", "value": "municipio,uf", "description": "Embute o objeto pai completo em cada linha, sob a chave da relação (multi-salto: uf via municipio). FK órfã vira null." },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const objs = pm.response.json().objects;",
                "pm.test('embute municipio e uf', () => { if (objs.length) { pm.expect(objs[0]).to.have.property('municipio'); pm.expect(objs[0]).to.have.property('uf'); } });"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "SQL (POST /v1/query)",
      "description": "Consulta SQL num subconjunto padrão. Corpo `{\"sql\": \"SELECT ...\"}` (ou o texto SQL puro). Suporta SELECT com aliases e `*`, FROM [projeto.]classe, INNER/LEFT/RIGHT JOIN com equi-join `ON a.x = b.y`, WHERE (=, <>, !=, <, <=, >, >=, LIKE, NOT LIKE, IN, IS [NOT] NULL, AND/OR/NOT), ORDER BY, FIRST n / LIMIT n OFFSET m, COALESCE, CAST(... AS INT|FLOAT|STRING|BOOL|DATE), UPPER/LOWER. Strings comparam com folding de caixa/acento por padrão (desative com ?ci=false/?ai=false na URL). O project vem do header X-Zado-Project ou de FROM projeto.classe.",
      "item": [
        {
          "name": "SELECT simples com LIKE",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": "{{baseUrl}}/v1/query",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sql\": \"SELECT id, nome FROM logradouro WHERE nome LIKE '%nio%ivo%' LIMIT 10\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('has rows array', () => pm.expect(pm.response.json().rows).to.be.an('array'));"
              ] }
            }
          ]
        },
        {
          "name": "Two-hop JOIN + ORDER BY + folding",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": "{{baseUrl}}/v1/query",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sql\": \"SELECT l.nome, m.nome AS cidade, u.sigla AS uf FROM logradouro l JOIN municipio m ON l.municipioCodigo = m.codigoIbge JOIN uf u ON m.codigoUf = u.codigoUf WHERE u.sigla = 'RN' AND m.nome = 'mossoro' AND l.nome LIKE '%nio%ivo%' ORDER BY l.nome LIMIT 10\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('projeta cidade e uf', () => { const r = pm.response.json().rows; if (r.length) { pm.expect(r[0]).to.have.property('cidade'); pm.expect(r[0]).to.have.property('uf'); } });"
              ] }
            }
          ]
        },
        {
          "name": "LEFT JOIN + COALESCE + IS NULL",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": "{{baseUrl}}/v1/query",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sql\": \"SELECT l.nome, COALESCE(m.nome, 'sem cidade') AS cidade FROM logradouro l LEFT JOIN municipio m ON l.municipioCodigo = m.codigoIbge WHERE m.codigoIbge IS NULL LIMIT 20\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "CAST + IN + comparação tipada",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": "{{baseUrl}}/v1/query",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sql\": \"SELECT sigla, CAST(codigoUf AS STRING) AS cod FROM uf WHERE codigoUf IN (24, 35) ORDER BY sigla\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Paginação keyset",
      "description": "Paginação keyset por id: `?limit=<n>&after=<id>`. A resposta traz `next_after` com o id do último objeto da página; use-o como `?after=<next_after>` para buscar a próxima página. `after=0` (ou ausente) começa do início.",
      "item": [
        {
          "name": "List objects (primeira página)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/classes/{{className}}/objects?limit=100&after=0",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1", "classes", "{{className}}", "objects" ],
              "query": [
                { "key": "limit", "value": "100", "description": "Tamanho da página." },
                { "key": "after", "value": "0", "description": "Cursor keyset: retorna objetos com id > after. 0 = do início." }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('has objects array', () => pm.expect(j.objects).to.be.an('array'));",
                "if (j.next_after !== undefined && j.next_after !== null) { pm.collectionVariables.set('nextAfter', j.next_after); }"
              ] }
            }
          ]
        },
        {
          "name": "List objects (próxima página, after=next_after)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/classes/{{className}}/objects?limit=100&after={{nextAfter}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "v1", "classes", "{{className}}", "objects" ],
              "query": [
                { "key": "limit", "value": "100" },
                { "key": "after", "value": "{{nextAfter}}", "description": "Use o `next_after` retornado pela página anterior." }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Checkpoint",
      "item": [
        {
          "name": "Trigger checkpoint",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/checkpoint",
            "description": "Dispara consolidação síncrona do WAL no arquivo de dados (copy-on-write + rename atômico). Útil ao fim de uma carga em massa, especialmente com o servidor em `--checkpoint-manual`."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 or 204', () => pm.expect([200,204]).to.include(pm.response.code));"
              ] }
            }
          ]
        }
      ]
    }
  ]
}
